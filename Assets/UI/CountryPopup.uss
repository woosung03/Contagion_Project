.popup-root {
    position: absolute;
    left: 50%;
    top: 30%;
    width: 320px;
    margin-left: -160px;
    background-color: rgba(15, 15, 25, 0.95);
    border-radius: 8px;
    padding: 16px;
}

.popup-title {
    color: white;
    font-size: 24px;
    -unity-font-style: bold;
    margin-bottom: 8px;
}

.popup-row {
    color: rgb(220, 220, 220);
    font-size: 18px;
    margin-bottom: 4px;
}

.popup-close {
    margin-top: 10px;
    height: 36px;
}
